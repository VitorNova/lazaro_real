"""
Dashboard API Routes.

Endpoints para estatísticas do dashboard.
"""

import logging
from datetime import datetime, timedelta
from typing import Any, Dict, List, Optional

from fastapi import APIRouter, Query, HTTPException
from pydantic import BaseModel

from app.services.supabase import get_supabase_service

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/api/dashboard", tags=["dashboard"])


# ============================================================================
# RESPONSE MODELS
# ============================================================================

class LeadStats(BaseModel):
    """Estatísticas de leads."""
    total: int = 0
    today: int = 0
    this_week: int = 0
    this_month: int = 0


class AgentStats(BaseModel):
    """Estatísticas de um agent."""
    agent_id: str
    agent_name: str
    leads: LeadStats


class DashboardStatsResponse(BaseModel):
    """Resposta do endpoint de estatísticas."""
    status: str = "success"
    period: str
    total_agents: int = 0
    total_leads: int = 0
    leads_today: int = 0
    leads_this_week: int = 0
    leads_this_month: int = 0
    agents: List[AgentStats] = []


# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

def get_date_ranges() -> Dict[str, datetime]:
    """Retorna as datas de referência para filtros."""
    now = datetime.utcnow()

    # Início de hoje (00:00:00 UTC)
    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)

    # Início da semana (segunda-feira)
    days_since_monday = now.weekday()
    week_start = today_start - timedelta(days=days_since_monday)

    # Início do mês
    month_start = now.replace(day=1, hour=0, minute=0, second=0, microsecond=0)

    return {
        "today": today_start,
        "week": week_start,
        "month": month_start,
    }


def count_leads_by_date(
    supabase,
    table_name: str,
    date_ranges: Dict[str, datetime]
) -> LeadStats:
    """
    Conta leads por período em uma tabela.

    Args:
        supabase: Cliente Supabase
        table_name: Nome da tabela de leads
        date_ranges: Dicionário com datas de referência

    Returns:
        LeadStats com contagens
    """
    stats = LeadStats()

    try:
        # Total de leads
        total_response = (
            supabase.client
            .table(table_name)
            .select("id", count="exact")
            .execute()
        )
        stats.total = total_response.count or 0

        # Leads de hoje
        today_response = (
            supabase.client
            .table(table_name)
            .select("id", count="exact")
            .gte("created_date", date_ranges["today"].isoformat())
            .execute()
        )
        stats.today = today_response.count or 0

        # Leads desta semana
        week_response = (
            supabase.client
            .table(table_name)
            .select("id", count="exact")
            .gte("created_date", date_ranges["week"].isoformat())
            .execute()
        )
        stats.this_week = week_response.count or 0

        # Leads deste mês
        month_response = (
            supabase.client
            .table(table_name)
            .select("id", count="exact")
            .gte("created_date", date_ranges["month"].isoformat())
            .execute()
        )
        stats.this_month = month_response.count or 0

    except Exception as e:
        logger.error(f"Erro ao contar leads em {table_name}: {e}")
        # Retorna stats zeradas em caso de erro

    return stats


# ============================================================================
# ROUTES
# ============================================================================

@router.get("/stats", response_model=DashboardStatsResponse)
async def get_dashboard_stats(
    period: str = Query(default="month", description="Período: day, week, month"),
    user_id: Optional[str] = Query(default=None, description="Filtrar por user_id"),
) -> DashboardStatsResponse:
    """
    Retorna estatísticas do dashboard.

    - **period**: Período de análise (day, week, month)
    - **user_id**: Opcional - filtrar por usuário

    Retorna:
    - Total de agents
    - Total de leads
    - Leads hoje
    - Leads esta semana
    - Leads este mês
    - Estatísticas por agent
    """
    try:
        supabase = get_supabase_service()
        date_ranges = get_date_ranges()

        # Buscar agents
        query = supabase.client.table("agents").select("id, name, table_leads, status, user_id")

        if user_id:
            query = query.eq("user_id", user_id)

        agents_response = query.execute()
        agents = agents_response.data or []

        # Inicializar resposta
        response = DashboardStatsResponse(
            period=period,
            total_agents=len(agents),
            agents=[],
        )

        # Calcular estatísticas por agent
        for agent in agents:
            table_leads = agent.get("table_leads")

            if not table_leads:
                continue

            try:
                agent_stats = count_leads_by_date(supabase, table_leads, date_ranges)

                response.agents.append(AgentStats(
                    agent_id=agent.get("id", ""),
                    agent_name=agent.get("name", "Unknown"),
                    leads=agent_stats,
                ))

                # Acumular totais
                response.total_leads += agent_stats.total
                response.leads_today += agent_stats.today
                response.leads_this_week += agent_stats.this_week
                response.leads_this_month += agent_stats.this_month

            except Exception as e:
                logger.warning(f"Erro ao processar agent {agent.get('id')}: {e}")
                continue

        logger.info(
            f"Dashboard stats: {response.total_agents} agents, "
            f"{response.total_leads} leads total"
        )

        return response

    except Exception as e:
        logger.error(f"Erro ao buscar estatísticas do dashboard: {e}")
        raise HTTPException(
            status_code=500,
            detail=f"Erro ao buscar estatísticas: {str(e)}"
        )


@router.get("/health")
async def dashboard_health() -> Dict[str, Any]:
    """Health check do módulo de dashboard."""
    return {
        "status": "ok",
        "module": "dashboard",
        "timestamp": datetime.utcnow().isoformat(),
    }
