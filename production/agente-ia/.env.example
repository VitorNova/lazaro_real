# =============================================================================
# AGENTE IA - CONFIGURACAO DE AMBIENTE
# Copie para .env e preencha com seus valores
# =============================================================================

# ===== SERVER =====
APP_ENV=production
HOST=0.0.0.0
PORT=3004
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== GOOGLE GEMINI AI =====
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=sua_chave_google_ai_studio_aqui
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=4096

# ===== SUPABASE =====
# Dashboard: https://supabase.com/dashboard
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui
SUPABASE_ANON_KEY=sua_anon_key_aqui

# ===== REDIS =====
REDIS_URL=redis://localhost:6379/0
# ou com senha: redis://:senha@localhost:6379/0

# ===== UAZAPI (WHATSAPP) =====
UAZAPI_BASE_URL=https://api.uazapi.com
UAZAPI_API_KEY=sua_chave_uazapi_aqui

# ===== LEADBOX =====
LEADBOX_BASE_URL=https://enterprise-135api.leadbox.app.br
LEADBOX_API_UUID=seu_uuid_leadbox
LEADBOX_API_KEY=sua_chave_leadbox

# ===== MESSAGE BUFFER =====
MESSAGE_BUFFER_DELAY_SECONDS=14
MESSAGE_BUFFER_TTL_SECONDS=300

# ===== AGENT CONFIG =====
DEFAULT_AGENT_UUID=uuid_do_agente_padrao
DEFAULT_AGENT_SHORT_ID=short_id_do_agente

# ===== GOOGLE CALENDAR (OPCIONAL) =====
# Opcao 1: Service Account (acesso a calendarios compartilhados)
# GOOGLE_CALENDAR_CREDENTIALS={"type":"service_account","project_id":"..."}
# GOOGLE_CALENDAR_ID=seu_calendario_id@group.calendar.google.com

# Opcao 2: OAuth2 (acesso ao calendario pessoal do usuario - RECOMENDADO)
# Obtenha em: https://console.cloud.google.com/apis/credentials
# O refresh_token e armazenado no Supabase (coluna google_credentials da tabela agents)
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# ===== ASAAS (OPCIONAL) =====
# ASAAS_API_KEY=sua_chave_asaas
# ASAAS_ENVIRONMENT=production
